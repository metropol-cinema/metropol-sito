# Read-API della programmazione (gestionale metropol-cinema)
PROGRAMMAZIONE_API_URL=https://app.cinemametropol.it/api/public/programmazione
# Token dedicato ai consumer di lettura (= PROGRAMMAZIONE_READ_TOKEN del gestionale). SOLO server-side.
PROGRAMMAZIONE_API_TOKEN=

# TMDB: backdrop orizzontali per gli hero e poster ottimizzati. Opzionale:
# senza chiave il sito usa le locandine data-URI di Cinebot.
TMDB_API_KEY=

# Deep-link di acquisto biglietti (piattaforma vendita online Cinebot).
# URL con segnaposto {eventId}, sostituito con l'id evento della proiezione.
# Esempio: https://vendita.example.com/acquista?evento={eventId}
# Finché è vuota, i bottoni "Acquista" non compaiono.
TICKET_URL_TEMPLATE=
